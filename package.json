{
  "name": "ainote-desktop",
  "version": "0.1.0",
  "description": "AiNote Desktop - The Digital Sanctuary",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && concurrently -k -n tsc,vite,electron \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "test": "tsx --tsconfig tsconfig.test.json --test tests/**/*.test.ts",
    "build": "tsc -p tsconfig.web.json && vite build && tsc -p tsconfig.node.json",
    "build:electron": "pnpm build && electron-builder --win",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@langchain/community": "^1.1.24",
    "@langchain/core": "^1.1.33",
    "@langchain/openai": "^1.3.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "12.35.2",
    "katex": "^0.16.22",
    "lucide-react": "^0.577.0",
    "nanoid": "5.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "10.1.0",
    "react-router-dom": "^7.13.0",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
